# Copie para .env.local e preencha (não commitar valores reais)

SUPABASE_URL=https://SEU-PROJECT-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
DATABASE_URL=postgresql://postgres.SEU-PROJECT-REF:[SENHA]@....pooler.supabase.com:6543/postgres

SESSION_SECRET=troque-por-uma-chave-aleatoria-com-pelo-menos-32-caracteres

# URL pública do CRM (produção Easypanel: https://app.somaconecta.com.br)
APP_URL=http://localhost:3090
CHAT_PUBLIC_BASE_URL=
PUBLIC_APP_URL=

# --- E-mail transacional ---
MAIL_MODE=smtp
MAIL_FROM=Drax Sistemas <draxsistemas@gmail.com>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=draxsistemas@gmail.com
SMTP_PASS=

# --- Chat WhatsApp + IA (Soma) ---
# Mesmo EVO do Easypanel (walkup) do WABA — instância EXCLUSIVA deste CRM.
OPENAI_API_KEY=
EVOLUTION_API_URL=https://walkup-evo-walkup-api.achpyp.easypanel.host
EVOLUTION_API_KEY=
# Obrigatório prefixo soma- (ex.: soma-crm). Nunca use instâncias do WABA/Aquecedor.
EVOLUTION_INSTANCE=soma-crm
# Header x-soma-webhook-secret (recomendado)
CHAT_WEBHOOK_SECRET=
# URL pública HTTPS do CRM (quando existir) para webhook só desta instância
CHAT_PUBLIC_BASE_URL=
